# Copy this file to .env.local (or .env) and fill in the values you need.
#
# You do NOT need Google credentials to try the app: click "Use Demo Mode"
# on the dashboard and the whole flow (list -> compose -> send -> track)
# works with simulated sends. Fill in the Google values below only when you
# want to send through a real Gmail account.

# --- Google OAuth (Gmail API) ---
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable the "Gmail API" (APIs & Services > Library).
# 3. APIs & Services > OAuth consent screen: set to "External" + add your
#    own Google account as a Test User (lets you skip Google's app review).
# 4. APIs & Services > Credentials > Create Credentials > OAuth client ID
#    > Web application. Add this Authorized redirect URI:
#      http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Base URL of the running app (used to build the OAuth redirect URI above
# when GOOGLE_REDIRECT_URI isn't set explicitly, e.g. on a Vercel deploy).
APP_BASE_URL=http://localhost:3000

# --- Data storage ---
# Optional override for where the JSON data store lives. Defaults to
# ./data locally, or /tmp/data automatically when deployed on Vercel
# (see src/lib/store.ts and WRITEUP.md for the tradeoffs of each).
DATA_DIR=./data